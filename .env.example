# ============================================================================
# BoothBooth — environment template. Copy to .env and fill in real values:
#     cp .env.example .env
# .env is git-ignored (holds real creds); THIS file is committed. Never put
# real secrets here — placeholders only.
# ============================================================================

# ── Postgres bootstrap superuser (used ONLY by init + the migrate step) ──
POSTGRES_USER=boothbooth
POSTGRES_PASSWORD=your-superuser-password-here
POSTGRES_DB=boothbooth

# ── App-role passwords (set at DB init by 02-set-passwords.sh) ──
# These MUST match the passwords embedded in the DATABASE_URL* values below.
BB_MIGRATE_PASSWORD=your-migrate-password-here
BB_APP_PASSWORD=your-app-password-here

# ── Connection strings (password must match the matching BB_*_PASSWORD above) ──
# Migration / DDL role — can CREATE EXTENSION + DDL; used by the migrate job.
DATABASE_URL_MIGRATE=postgres://bb_migrate:your-migrate-password-here@postgres:5432/boothbooth
# Runtime DML role — least-privilege; used by the api service.
DATABASE_URL=postgres://bb_app:your-app-password-here@postgres:5432/boothbooth

# ── API service ──
NODE_ENV=development                       # set to "production" in prod
SESSION_COOKIE_SECRET=your-32+char-random-secret-here   # signs the session cookie
COOKIE_SECURE=false                        # set to "true" in prod (requires TLS)
EXPO_TZ=Africa/Lagos                       # IANA tz for "today" KPI/Daily-Log boundaries
